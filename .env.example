# Airtable
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Google Calendar (path to service account JSON file)
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Twilio SMS
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+15550001234

# Canva Connect API (for ad creative generation — run scripts/canva_auth.py to populate tokens)
CANVA_CLIENT_ID=OC-XXXXXXXXXXXXXXXX
CANVA_CLIENT_SECRET=your_client_secret_here
CANVA_ACCESS_TOKEN=
CANVA_REFRESH_TOKEN=

# Cleaner Report App — email notifications
# Use your Gmail address + an App Password (myaccount.google.com → Security → App passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hello@paradiseshinecleaning.com
SMTP_PASSWORD=your_gmail_app_password_here
NOTIFY_EMAIL=hello@paradiseshinecleaning.com

# GoHighLevel inbound webhook URL (report data forwarded here in background)
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/rThu0gTECSkUU9WybMZx/webhook-trigger/0e8024e5-cd19-4ac9-bed9-ffcd27fcc3c2

# Sync behavior (optional — defaults shown)
SYNC_LOOKAHEAD_DAYS=90
SYNC_LOOKBACK_DAYS=1
